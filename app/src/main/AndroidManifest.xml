<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:installLocation="auto">

    <uses-permission android:name="android.permission.INTERNET" />

    <attribution
        android:label="@string/app_name"
        android:tag="google_ads_attribution_tag" />
    <attribution
        android:label="@string/app_name"
        android:tag="audioPlayback" />
    <attribution
        android:label="@string/app_name"
        android:tag="@string/empty" />

    <application
        android:icon="@drawable/blindman"
        android:label="@string/app_name"
        android:theme="@style/BlindmanTheme">
        <activity
            android:name=".BlindManActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.GAME" />
            </intent-filter>
        </activity>
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="@string/ad_unit_manifest_id" />
    </application>

</manifest>
